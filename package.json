{
  "name": "veritas-worldwide",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-runtime.mjs",
    "dev:vite": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "postbuild": "node scripts/export-chapter-data.mjs && node scripts/prerender.mjs",
    "start": "node server.js",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "verify:auth": "node scripts/verify-auth-flows.mjs",
    "verify:auth-cache": "node --experimental-strip-types scripts/verify-auth-cache-isolation.mjs",
    "verify:auth-cache-browser": "node scripts/verify-auth-cache-browser.mjs",
    "verify:dev-runtime": "node scripts/verify-dev-runtime.mjs",
    "verify:sources": "node scripts/verify-source-links.mjs",
    "verify:analytics": "node scripts/verify-analytics-snapshot.mjs",
    "verify:release": "node scripts/verify-release-identity.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "pg": "^8.20.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
